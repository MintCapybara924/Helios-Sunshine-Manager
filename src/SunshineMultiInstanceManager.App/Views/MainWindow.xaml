<ui:FluentWindow
    x:Class="Helios.App.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Helios.App.Views.Controls"
    xmlns:vm="clr-namespace:Helios.App.ViewModels"
    mc:Ignorable="d"
    Title="Helios - Sunshine Multi-Instance Manager"
    Icon="/Assets/SMIM.ico"
    Width="900"
    Height="600"
    MinWidth="720"
    MinHeight="480"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 鈹€鈹€ TitleBar 鈹€鈹€ -->
        <ui:TitleBar
            x:Name="MainTitleBar"
            Grid.Row="0"
            Title="Helios - Sunshine Multi-Instance Manager"
            ShowMinimize="True"
            ShowMaximize="True"
            ShowClose="True"/>

        <!-- 鈹€鈹€ 涓诲収瀹?鈹€鈹€ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="200" MaxWidth="380"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- 宸︽瑒锛氬渚嬫竻鍠?-->
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <local:InstanceListView DataContext="{Binding}"/>
            </Border>

            <!-- 鍒嗛殧鎷栧嫊姊?-->
            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                Opacity="0.3"/>

            <!-- 鍙虫瑒锛氱法杓潰鏉?+ Busy 閬僵 -->
            <Grid Grid.Column="2">
                <local:InstanceEditorView DataContext="{Binding}"/>

                <Border
                    Background="#80000000"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
                        <TextBlock Text="{Binding BusyText}" HorizontalAlignment="Center"
                                   Foreground="White" FontSize="14" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource ControlAltFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <Expander Header="{Binding RuntimeLogTitle}" IsExpanded="{Binding IsLogExpanded, Mode=TwoWay}">
                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <local:SpacedStackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                        <ui:Button Command="{Binding ClearLogCommand}"
                                   Content="{Binding ClearLogText}"
                                   Height="24"
                                   FontSize="11"
                                   Padding="8,0"
                                   Appearance="Secondary"/>
                    </local:SpacedStackPanel>

                    <TextBox Grid.Row="1"
                             Margin="0,6,0,0"
                             Height="140"
                             Text="{Binding LiveLogText, Mode=OneWay}"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"
                             FontFamily="Consolas"
                             FontSize="12"/>
                </Grid>
            </Expander>
        </Border>

        <!-- 鈹€鈹€ 鐙€鎱嬪垪 鈹€鈹€ -->
        <Border
            Grid.Row="3"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="{Binding StatusText}"
                    FontSize="12"
                    VerticalAlignment="Center"
                    Opacity="0.8"/>

                <local:SpacedStackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBlock
                        Text="{Binding ThemeQuickSwitchText}"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Opacity="0.8"/>
                    <ui:ToggleSwitch
                        IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                        VerticalAlignment="Center"
                        ToolTip="{Binding CurrentThemeText}"/>
                    <TextBlock
                        Text="{Binding CurrentThemeText}"
                        FontSize="11"
                        VerticalAlignment="Center"
                        Opacity="0.8"/>
                    <ui:Button
                        Command="{Binding StartAllCommand}"
                        Content="{Binding StartAllText}"
                        FontSize="11"
                        Height="24"
                        Padding="8,0"
                        Appearance="Primary"/>
                    <ui:Button
                        Command="{Binding StopAllCommand}"
                        Content="{Binding StopAllText}"
                        FontSize="11"
                        Height="24"
                        Padding="8,0"
                        Appearance="Secondary"/>
                    <ui:Button
                        x:Name="OpenSettingsButton"
                        Click="OpenSettings_Click"
                        FontSize="11"
                        Height="24"
                        Padding="8,0"
                        ToolTip="闁嬪暉瑷畾">
                        <local:SpacedStackPanel Orientation="Horizontal" Spacing="4">
                            <ui:SymbolIcon Symbol="Settings16"/>
                            <TextBlock x:Name="OpenSettingsButtonText" Text="瑷畾"/>
                        </local:SpacedStackPanel>
                    </ui:Button>
                </local:SpacedStackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>

