<UserControl
    x:Class="SunshineMultiInstanceManager.App.Views.Controls.InstanceListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:SunshineMultiInstanceManager.App.Views.Controls"
    xmlns:vm="clr-namespace:SunshineMultiInstanceManager.App.ViewModels"
    mc:Ignorable="d"
    d:DesignHeight="500"
    d:DesignWidth="260">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 鈹€鈹€ 宸ュ叿鍒楋細鏂板 / 瑜囪＝ / 鍒櫎 鈹€鈹€ -->
        <local:SpacedStackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    Margin="8,8,8,4"
                    Spacing="4">

            <ui:Button
                Command="{Binding AddInstanceCommand}"
                ToolTip="{Binding TipAddText}"
                Appearance="Primary"
                MinWidth="78"
                MinHeight="30"
                Padding="8,2"
                FontSize="12">
                <local:SpacedStackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Add16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ListAddText}" VerticalAlignment="Center"/>
                </local:SpacedStackPanel>
            </ui:Button>

            <ui:Button
                Command="{Binding CloneInstanceCommand}"
                ToolTip="{Binding TipCloneText}"
                MinWidth="78"
                MinHeight="30"
                Padding="8,2"
                FontSize="12">
                <local:SpacedStackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Copy16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ListCloneText}" VerticalAlignment="Center"/>
                </local:SpacedStackPanel>
            </ui:Button>

            <ui:Button
                Command="{Binding DeleteInstanceCommand}"
                ToolTip="{Binding TipDeleteText}"
                Appearance="Danger"
                MinWidth="78"
                MinHeight="30"
                Padding="8,2"
                FontSize="12">
                <local:SpacedStackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Delete16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ListDeleteText}" VerticalAlignment="Center"/>
                </local:SpacedStackPanel>
            </ui:Button>
        </local:SpacedStackPanel>

        <!-- 鈹€鈹€ 瀵︿緥娓呭柈 鈹€鈹€ -->
        <ListBox
            Grid.Row="1"
            Margin="8,4,8,8"
            ItemsSource="{Binding Instances}"
            SelectedItem="{Binding SelectedInstance}"
            SelectionMode="Single"
            Background="Transparent"
            BorderThickness="0">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding"                    Value="8,6"/>
                    <Setter Property="Margin"                     Value="0,2"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border
                                    x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource SystemAccentColorBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:InstanceViewModel}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 鐙€鎱嬫寚绀虹噲 -->
                        <Ellipse Grid.Column="0"
                                 Width="10" Height="10"
                                 VerticalAlignment="Center">
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding RunStatusColor}"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <!-- 鍚嶇ū + 鐙€鎱?-->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock
                                Text="{Binding Name}"
                                FontSize="13"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis"/>
                            <TextBlock
                                Text="{Binding RunStatusText}"
                                FontSize="11"
                                Opacity="0.65"/>
                        </StackPanel>

                        <!-- Port 妯欑堡 -->
                        <Border Grid.Column="3"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                CornerRadius="4"
                                Padding="6,2"
                                VerticalAlignment="Center"
                                Margin="6,0,0,0">
                            <TextBlock Text="{Binding Port}" FontSize="11" Opacity="0.85"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
