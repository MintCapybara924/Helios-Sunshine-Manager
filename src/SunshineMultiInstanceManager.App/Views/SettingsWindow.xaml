<ui:FluentWindow
    x:Class="Helios.App.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Helios.App.Views.Controls"
    xmlns:vm="clr-namespace:Helios.App.ViewModels"
    mc:Ignorable="d"
    Title="{Binding AppNameText}"
    Icon="/Assets/SMIM.ico"
    Width="480"
    Height="560"
    MinWidth="400"
    MinHeight="440"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBool"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 鈹€鈹€ TitleBar 鈹€鈹€ -->
        <ui:TitleBar
            x:Name="SettingsTitleBar"
            Grid.Row="0"
            Title="{Binding SettingsText}"
            ShowMinimize="False"
            ShowMaximize="False"
            ShowClose="True"/>

        <!-- 鈹€鈹€ 鍏у 鈹€鈹€ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <local:SpacedStackPanel Margin="16,12,16,16" Spacing="12">

                <!-- 鈹€鈹€ 瑾炶█ 鈹€鈹€ -->
                <ui:CardExpander Header="{Binding LanguageText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">
                        <TextBlock
                            Text="{Binding LanguageHintText}"
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.65"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Text="{Binding LanguageText}"
                                VerticalAlignment="Center"
                                FontSize="13"
                                FontWeight="Medium"/>
                            <ComboBox
                                Grid.Column="1"
                                ItemsSource="{Binding LanguageOptions}"
                                SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}"
                                SelectedValuePath="Code"
                                DisplayMemberPath="DisplayName"
                                VerticalAlignment="Center"/>
                        </Grid>
                    </local:SpacedStackPanel>
                </ui:CardExpander>

                <!-- 鈹€鈹€ Vibeshine 瀹夎 / 鏇存柊 鈹€鈹€ -->
                <ui:CardExpander Header="{Binding GroupVibeshineText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock
                                    Text="{Binding ProductBranchText}"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding ProductBranchHintText}"
                                    FontSize="11"
                                    Opacity="0.65"/>
                            </StackPanel>
                            <ComboBox
                                Grid.Column="1"
                                ItemsSource="{Binding ProductOptions}"
                                SelectedValue="{Binding SelectedProductCode, Mode=TwoWay}"
                                SelectedValuePath="Code"
                                DisplayMemberPath="DisplayName"
                                VerticalAlignment="Center"/>
                        </Grid>

                        <local:SpacedStackPanel Spacing="4">
                            <TextBlock
                                Text="{Binding ProductTargetFolderText}"
                                FontSize="12"
                                Opacity="0.8"/>
                            <TextBlock
                                Text="{Binding ProductTargetFolderHintText}"
                                FontSize="11"
                                Opacity="0.65"/>
                            <ui:TextBox
                                Text="{Binding SelectedProductTargetFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="12"/>
                        </local:SpacedStackPanel>

                        <TextBlock
                            Text="{Binding VibeshineDescText}"
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.65"/>

                        <!-- 鐗堟湰鐙€鎱嬪垪 -->
                        <Border
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <!-- 宸插畨瑁濈増鏈?-->
                                    <TextBlock FontSize="12" FontWeight="Medium" Text="{Binding InstalledDisplayText}"/>
                                    <!-- 鏈€鏂扮増鏈瘮灏嶈▕鎭?-->
                                    <TextBlock
                                        Text="{Binding UpdateAvailableText}"
                                        FontSize="11"
                                        Opacity="0.7"
                                        TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UpdateAvailableText}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                                <!-- 妾㈡煡鏇存柊鎸夐垥 -->
                                <ui:Button
                                    Grid.Column="1"
                                    Content="{Binding CheckUpdateText}"
                                    FontSize="11"
                                    Height="28"
                                    Padding="10,0"
                                    Command="{Binding CheckForUpdateCommand}"
                                    IsEnabled="{Binding IsCheckingUpdate,
                                        Converter={StaticResource InverseBool}}"/>
                            </Grid>
                        </Border>

                        <!-- 鍖呭惈闋愯鐗?Toggle -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding IncludeBetaText}"
                                           FontSize="12" FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding BetaHintText}"
                                    FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IncludePreRelease, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 涓嬭級閫插害鍒楋紙涓嬭級涓墠椤ず锛?-->
                        <ProgressBar
                            Value="{Binding DownloadProgress}"
                            Minimum="0"
                            Maximum="100"
                            Height="6">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInstalling}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>

                        <!-- 涓嬭級涓﹀畨瑁?/ 鏇存柊 鎸夐垥锛堟煡瑭㈠埌鐗堟湰寰屾墠椤ず锛?-->
                        <ui:Button
                            Command="{Binding DownloadAndInstallCommand}"
                            Appearance="Primary"
                            HorizontalAlignment="Stretch"
                            FontSize="13"
                            Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding IsInstalling, Converter={StaticResource InverseBool}}">
                            <local:SpacedStackPanel Orientation="Horizontal" Spacing="6">
                                <ui:SymbolIcon Symbol="ArrowDownload16"/>
                                <!-- Download button label changes by install state -->
                                <TextBlock>
                                    <Run Text="{Binding DownloadActionText, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding LatestRelease.TagName, StringFormat='({0})'}"
                                           Opacity="0.75"/>
                            </local:SpacedStackPanel>
                        </ui:Button>

                    </local:SpacedStackPanel>
                </ui:CardExpander>

                <!-- Autostart -->
                <ui:CardExpander Header="{Binding GroupAutoStartText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">

                        <TextBlock
                            Text="{Binding AutoStartInfoText}"
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.65"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding AutoStartTitleText}"
                                           FontSize="13" FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding AutoStartDescText}"
                                    FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IsAutoStartEnabled, Mode=TwoWay}"
                                IsEnabled="{Binding IsAutoStartBusy,
                                    Converter={StaticResource InverseBool}}"
                                VerticalAlignment="Center"/>
                        </Grid>

                    </local:SpacedStackPanel>
                </ui:CardExpander>

                <!-- 鈹€鈹€ 闊抽噺鍚屾 鈹€鈹€ -->
                <ui:CardExpander Header="{Binding GroupVolumeText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">

                        <TextBlock
                            Text="{Binding VolumeInfoText}"
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.65"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding VolumeTitleText}"
                                           FontSize="13" FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding VolumeDescText}"
                                    FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IsSyncVolumeEnabled, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        </Grid>

                    </local:SpacedStackPanel>
                </ui:CardExpander>

                <!-- 鈹€鈹€ 椤ず鍣ㄨō瀹?鈹€鈹€ -->
                <ui:CardExpander Header="{Binding GroupDisplayText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">

                        <!-- SyncOnDisplayChange -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayRestartTitleText}"
                                           FontSize="13" FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding DisplayRestartDescText}"
                                    FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IsSyncOnDisplayChange, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        </Grid>

                        <!-- RemoveDisplayOnDisconnect -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayRemoveTitleText}"
                                           FontSize="13" FontWeight="Medium"/>
                                <TextBlock
                                    Text="{Binding DisplayRemoveDescText}"
                                    FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IsRemoveDisplayOnDisconnect, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        </Grid>

                    </local:SpacedStackPanel>
                </ui:CardExpander>

                <!-- 鈹€鈹€ SunshineService 鈹€鈹€ -->
                <ui:CardExpander Header="{Binding GroupServiceText}" IsExpanded="True">
                    <local:SpacedStackPanel Spacing="10" Margin="0,8,0,0">

                        <TextBlock
                            Text="{Binding ServiceInfoText}"
                            TextWrapping="Wrap"
                            FontSize="11"
                            Opacity="0.65"/>

                        <!-- 鐙€鎱嬪垪 -->
                        <Border
                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        Text="{Binding ServiceTargetsText}"
                                        FontSize="12"
                                        FontWeight="Medium"/>
                                    <TextBlock
                                        Text="{Binding ServiceReminderHintText}"
                                        FontSize="11"
                                        Opacity="0.7"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 一鍵停用提醒服務 -->
                        <ui:Button
                            Command="{Binding DisableSunshineServiceCommand}"
                            Content="{Binding DisableServiceText}"
                            FontSize="12"
                            Appearance="Secondary"
                            HorizontalAlignment="Stretch"
                            IsEnabled="{Binding IsServiceBusy,
                                Converter={StaticResource InverseBool}}"/>

                    </local:SpacedStackPanel>
                </ui:CardExpander>

            </local:SpacedStackPanel>
        </ScrollViewer>

        <!-- 鈹€鈹€ 鐙€鎱嬭▕鎭垪 鈹€鈹€ -->
        <Border
            Grid.Row="2"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Text="{Binding StatusMessage}"
                    FontSize="11"
                    Opacity="0.75"
                    TextWrapping="Wrap"/>
                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    Text="{Binding AppVersionText}"
                    FontSize="11"
                    Opacity="0.6"
                    VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>

</ui:FluentWindow>

